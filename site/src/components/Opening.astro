---
/* Full-viewport opening — the first thing anyone sees.
   Clean, confident, breathing space. */
---

<section class="opening" aria-label="Welcome">
  <h1 class="opening__title">Perpetual Petals</h1>
  <div class="opening__line" aria-hidden="true"></div>
  <p class="opening__subtitle">Private Floral Membership</p>
  <p class="opening__location">Windermere, Florida</p>
  <div class="opening__scroll" aria-hidden="true">
    <div class="opening__scroll-line"></div>
  </div>
</section>

<style>
  .opening {
    min-height: 100vh;
    min-height: 100dvh;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    text-align: center;
    background: var(--color-cream);
    background-image: radial-gradient(ellipse at center, rgba(201, 160, 142, 0.06), transparent 70%);
    position: relative;
    padding: var(--space-lg) var(--space-md);
  }

  .opening__title {
    font-family: var(--font-serif);
    font-weight: 300;
    font-size: clamp(48px, 10vw, 100px);
    color: var(--color-ink);
    letter-spacing: 3px;
    line-height: 1.05;
    opacity: 0;
    animation: titleReveal 1.6s var(--ease-out) 0.3s forwards;
  }

  @keyframes titleReveal {
    from { opacity: 0; letter-spacing: 6px; }
    to   { opacity: 1; letter-spacing: 3px; }
  }

  .opening__line {
    width: 50px;
    height: 1px;
    background: var(--color-rose);
    margin: 28px auto 24px;
    opacity: 0;
    animation: fadeIn 0.8s var(--ease-out) 1s forwards;
  }

  .opening__subtitle {
    font-family: var(--font-sans);
    font-weight: 500;
    font-size: 11px;
    letter-spacing: 4px;
    text-transform: uppercase;
    color: var(--color-rose);
    opacity: 0;
    animation: fadeIn 0.8s var(--ease-out) 1.3s forwards;
  }

  .opening__location {
    font-family: var(--font-sans);
    font-weight: 400;
    font-size: 11px;
    letter-spacing: 3px;
    text-transform: uppercase;
    color: var(--color-ink-muted);
    margin-top: 8px;
    opacity: 0;
    animation: fadeIn 0.8s var(--ease-out) 1.5s forwards;
  }

  @keyframes fadeIn {
    to { opacity: 1; }
  }

  .opening__scroll {
    position: absolute;
    bottom: 36px;
    left: 50%;
    transform: translateX(-50%);
    opacity: 0;
    animation: fadeIn 0.6s var(--ease-out) 2.2s forwards, scrollPulse 2.5s ease-in-out 3s infinite;
  }

  .opening__scroll-line {
    width: 1px;
    height: 40px;
    background: linear-gradient(to bottom, var(--color-rose), transparent);
  }

  @keyframes scrollPulse {
    0%, 100% { transform: translateX(-50%) translateY(0); opacity: 0.6; }
    50%      { transform: translateX(-50%) translateY(8px); opacity: 0.25; }
  }

  @media (prefers-reduced-motion: reduce) {
    .opening__title,
    .opening__line,
    .opening__subtitle,
    .opening__location,
    .opening__scroll {
      opacity: 1;
      animation: none;
    }
  }
</style>
