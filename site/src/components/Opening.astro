---
/**
 * Opening Section — Full-viewport hero with animated title reveal,
 * scroll-driven parallax gradient, gold botanical ornament, and scroll indicator.
 */
---

<section class="opening" aria-label="Welcome">
  <!-- Parallax gradient overlay that shifts on scroll -->
  <div class="opening__gradient-overlay" aria-hidden="true"></div>

  <h1 class="opening__title">Perpetual Petals</h1>

  <!-- Gold botanical ornament: 5 petal ellipses + center circle -->
  <div class="opening__ornament" aria-hidden="true">
    <svg class="opening__ornament-svg" viewBox="0 0 160 32" fill="none" xmlns="http://www.w3.org/2000/svg">
      <line x1="0" y1="16" x2="56" y2="16" stroke="currentColor" stroke-width="0.5" />
      <g transform="translate(80, 16)">
        <ellipse cx="0" cy="-5" rx="2.5" ry="6" transform="rotate(-36)" fill="none" stroke="currentColor" stroke-width="0.5" opacity="0.8" />
        <ellipse cx="0" cy="-5" rx="2.5" ry="6" transform="rotate(-18)" fill="none" stroke="currentColor" stroke-width="0.5" opacity="0.8" />
        <ellipse cx="0" cy="-5" rx="2.5" ry="6" transform="rotate(0)" fill="none" stroke="currentColor" stroke-width="0.5" opacity="0.8" />
        <ellipse cx="0" cy="-5" rx="2.5" ry="6" transform="rotate(18)" fill="none" stroke="currentColor" stroke-width="0.5" opacity="0.8" />
        <ellipse cx="0" cy="-5" rx="2.5" ry="6" transform="rotate(36)" fill="none" stroke="currentColor" stroke-width="0.5" opacity="0.8" />
        <circle cx="0" cy="0" r="1.2" fill="currentColor" opacity="0.6" />
      </g>
      <line x1="104" y1="16" x2="160" y2="16" stroke="currentColor" stroke-width="0.5" />
    </svg>
  </div>

  <p class="opening__subtitle">Private Floral Membership</p>
  <p class="opening__location">Windermere, Florida</p>

  <div class="scroll-indicator" aria-hidden="true">
    <div class="scroll-indicator__line"></div>
  </div>
</section>

<style>
  /* ============================================
     OPENING — Full Viewport Hero
     ============================================ */

  .opening {
    min-height: 100vh;
    min-height: 100dvh;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    text-align: center;
    background: var(--color-cream, #FBF7F4);
    background-image: radial-gradient(
      ellipse at center,
      rgba(184, 117, 122, 0.05),
      transparent 70%
    );
    position: relative;
    padding: 40px 24px;
    overflow: hidden;
  }

  /* Gradient overlay for parallax scroll effect */
  .opening__gradient-overlay {
    position: absolute;
    inset: 0;
    background: radial-gradient(
      ellipse at 50% 50%,
      rgba(184, 117, 122, 0.08),
      transparent 70%
    );
    opacity: 0;
    transition: opacity 0.3s ease;
    pointer-events: none;
    will-change: opacity, background;
  }

  /* ---- Title ---- */

  .opening__title {
    font-family: 'Cormorant Garamond', serif;
    font-weight: 300;
    font-size: clamp(56px, 10vw, 120px);
    color: var(--color-ink, #2A2119);
    letter-spacing: 2px;
    line-height: 1.1;
    position: relative;
    z-index: 1;
  }

  /* ---- Gold Botanical Ornament ---- */

  .opening__ornament {
    color: var(--color-gold, #C9A87C);
    margin: 24px auto 20px;
    opacity: 0;
    animation: ornamentReveal 1s ease 1s forwards;
    position: relative;
    z-index: 1;
  }

  .opening__ornament-svg {
    width: 160px;
    height: 32px;
    display: block;
  }

  @keyframes ornamentReveal {
    from {
      opacity: 0;
      transform: scaleX(0.3);
    }
    to {
      opacity: 1;
      transform: scaleX(1);
    }
  }

  /* ---- Subtitle & Location ---- */

  .opening__subtitle {
    font-family: 'Raleway', sans-serif;
    font-weight: 500;
    font-size: 13px;
    letter-spacing: 3px;
    text-transform: uppercase;
    color: var(--color-rose, #855E4A);
    opacity: 0;
    animation: fadeInUp 0.8s ease 1.3s forwards;
    position: relative;
    z-index: 1;
  }

  .opening__location {
    font-family: 'Raleway', sans-serif;
    font-weight: 300;
    font-size: 13px;
    letter-spacing: 3px;
    text-transform: uppercase;
    color: var(--color-ink-muted, #9A8E85);
    margin-top: 6px;
    opacity: 0;
    animation: fadeInUp 0.8s ease 1.5s forwards;
    position: relative;
    z-index: 1;
  }

  @keyframes fadeInUp {
    from {
      opacity: 0;
      transform: translateY(6px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  /* ---- Scroll Indicator ---- */

  .scroll-indicator {
    position: absolute;
    bottom: 32px;
    left: 50%;
    transform: translateX(-50%);
    opacity: 0;
    animation: fadeIn 0.8s ease 2s forwards, scrollPulse 2.5s ease-in-out 2.8s infinite;
    transition: opacity 0.6s ease, transform 0.6s ease;
  }

  .scroll-indicator.hidden {
    opacity: 0 !important;
    transform: translateX(-50%) translateY(12px);
    pointer-events: none;
  }

  .scroll-indicator__line {
    width: 1.5px;
    height: 48px;
    background: linear-gradient(
      to bottom,
      var(--color-rose, #855E4A),
      transparent
    );
    margin: 0 auto;
  }

  @keyframes fadeIn {
    to { opacity: 1; }
  }

  @keyframes scrollPulse {
    0%, 100% {
      transform: translateX(-50%) translateY(0);
      opacity: 0.6;
    }
    50% {
      transform: translateX(-50%) translateY(8px);
      opacity: 0.3;
    }
  }

  /* ============================================
     prefers-reduced-motion
     ============================================ */

  @media (prefers-reduced-motion: reduce) {
    .opening__title {
      opacity: 1;
      transform: none;
      animation: none;
      letter-spacing: 2px;
    }

    .opening__ornament {
      opacity: 1;
      transform: none;
      animation: none;
    }

    .opening__subtitle,
    .opening__location {
      opacity: 1;
      transform: none;
      animation: none;
    }

    .scroll-indicator {
      opacity: 0.6;
      animation: none;
    }

    .scroll-indicator.hidden {
      opacity: 0 !important;
      transform: translateX(-50%);
    }

    .opening__gradient-overlay {
      display: none;
    }
  }
</style>

<script>
  (function () {
    'use strict';

    const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    const opening = document.querySelector('.opening') as HTMLElement | null;
    const gradientOverlay = document.querySelector('.opening__gradient-overlay') as HTMLElement | null;
    const scrollIndicator = document.querySelector('.scroll-indicator') as HTMLElement | null;

    if (!opening) return;

    let scrollHidden = false;
    let ticking = false;

    function onScroll() {
      if (ticking) return;
      ticking = true;

      requestAnimationFrame(() => {
        const scrollY = window.scrollY;
        const viewportHeight = window.innerHeight;

        // Hide scroll indicator after user scrolls past ~10% of viewport
        if (!scrollHidden && scrollIndicator && scrollY > viewportHeight * 0.1) {
          scrollIndicator.classList.add('hidden');
          scrollHidden = true;
        }

        // Parallax gradient shift — only when opening is in view and motion is allowed
        if (!prefersReducedMotion && gradientOverlay && scrollY < viewportHeight) {
          const progress = scrollY / viewportHeight;
          const yOffset = 50 + progress * 25;
          gradientOverlay.style.opacity = String(Math.min(progress * 1.5, 1));
          gradientOverlay.style.background = `radial-gradient(
            ellipse at 50% ${yOffset}%,
            rgba(184, 117, 122, ${0.04 + progress * 0.08}),
            transparent 70%
          )`;
        }

        ticking = false;
      });
    }

    window.addEventListener('scroll', onScroll, { passive: true });
  })();
</script>
