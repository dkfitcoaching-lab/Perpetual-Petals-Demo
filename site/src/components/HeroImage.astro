---
/* Full-bleed hero image with soft gradient edges */
---

<section class="hero-image reveal" aria-label="Featured arrangement">
  <picture>
    <source
      type="image/webp"
      srcset="/images/hero-arrangement-400w.webp 400w, /images/hero-arrangement-800w.webp 800w, /images/hero-arrangement-1200w.webp 1200w, /images/hero-arrangement-1800w.webp 1800w"
      sizes="100vw"
    >
    <source
      type="image/png"
      srcset="/images/hero-arrangement-400w.png 400w, /images/hero-arrangement-800w.png 800w, /images/hero-arrangement-1200w.png 1200w, /images/hero-arrangement-1800w.png 1800w"
      sizes="100vw"
    >
    <img
      src="/images/hero-arrangement.png"
      alt="A lush arrangement of premium garden roses in soft pinks and creams by Perpetual Petals"
      fetchpriority="high"
      width="1800"
      height="1200"
    >
  </picture>
</section>

<style>
  .hero-image {
    width: 100%;
    overflow: hidden;
    position: relative;
  }

  .hero-image::after {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(
      to bottom,
      var(--color-cream) 0%,
      transparent 12%,
      transparent 88%,
      var(--color-cream) 100%
    );
    pointer-events: none;
  }

  .hero-image img {
    width: 100%;
    height: 55vh;
    object-fit: cover;
  }

  @media (min-width: 768px) {
    .hero-image img {
      height: 80vh;
    }
  }
</style>
