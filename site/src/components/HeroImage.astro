---
/**
 * Full-bleed hero image with warm overlay, soft edge fades,
 * and parallax scroll effect via requestAnimationFrame.
 */
---

<section class="hero-image" aria-label="Featured arrangement">
  <div class="hero-image__warm-overlay" aria-hidden="true"></div>
  <div class="hero-image__edge-fade" aria-hidden="true"></div>
  <picture>
    <source
      type="image/webp"
      srcset="/images/hero-arrangement-400w.webp 400w, /images/hero-arrangement-800w.webp 800w, /images/hero-arrangement-1200w.webp 1200w, /images/hero-arrangement-1800w.webp 1800w"
      sizes="100vw"
    >
    <source
      type="image/png"
      srcset="/images/hero-arrangement-400w.png 400w, /images/hero-arrangement-800w.png 800w, /images/hero-arrangement-1200w.png 1200w, /images/hero-arrangement-1800w.png 1800w"
      sizes="100vw"
    >
    <img
      src="/images/hero-arrangement.png"
      alt="A lush arrangement of premium garden roses in soft pinks and creams by Perpetual Petals"
      fetchpriority="high"
      width="1800"
      height="1200"
    >
  </picture>
</section>

<style>
  /* ============================================
     HERO IMAGE — Full Width
     ============================================ */

  .hero-image {
    width: 100%;
    overflow: hidden;
    position: relative;
  }

  /* Warm overlay: subtle pink-to-dark gradient */
  .hero-image__warm-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      to bottom,
      rgba(184, 117, 122, 0.04),
      rgba(26, 21, 22, 0.06)
    );
    pointer-events: none;
    z-index: 1;
  }

  /* Soft edge fade: cream at top and bottom */
  .hero-image__edge-fade {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      to bottom,
      var(--color-cream, #FBF7F4) 0%,
      transparent 6%,
      transparent 94%,
      var(--color-cream, #FBF7F4) 100%
    );
    pointer-events: none;
    z-index: 2;
  }

  .hero-image img {
    width: 100%;
    height: 65vh;
    object-fit: cover;
    display: block;
  }

  @media (min-width: 768px) {
    .hero-image img {
      height: 85vh;
    }
  }

  /* With motion preference: taller heights for parallax headroom */
  @media (prefers-reduced-motion: no-preference) {
    .hero-image img {
      height: 70vh;
      transform: translateZ(0);
      will-change: transform;
    }

    @media (min-width: 768px) {
      .hero-image img {
        height: 90vh;
      }
    }
  }
</style>

<script>
  // Parallax: 20% scroll offset via requestAnimationFrame
  if (window.matchMedia('(prefers-reduced-motion: no-preference)').matches) {
    const hero = document.querySelector('.hero-image img') as HTMLElement | null;
    if (hero) {
      let ticking = false;
      window.addEventListener('scroll', () => {
        if (!ticking) {
          ticking = true;
          requestAnimationFrame(() => {
            const offset = window.scrollY;
            hero.style.transform = `translateY(${offset * 0.2}px)`;
            ticking = false;
          });
        }
      }, { passive: true });
    }
  }
</script>
