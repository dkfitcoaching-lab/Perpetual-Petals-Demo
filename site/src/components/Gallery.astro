---
/* Portfolio gallery — masonry-ish grid */
const images = [
  {
    src: '/images/gallery-1.png',
    webpSrcset: '/images/gallery-1-400w.webp 400w, /images/gallery-1-800w.webp 800w, /images/gallery-1-1200w.webp 1200w',
    fallbackSrcset: '/images/gallery-1-400w.png 400w, /images/gallery-1-800w.png 800w, /images/gallery-1-1200w.png 1200w',
    fallbackType: 'image/png',
    alt: 'Garden rose arrangement in a ceramic vessel',
    width: 1600, height: 1200,
  },
  {
    src: '/images/gallery-2.jpeg',
    webpSrcset: '/images/gallery-2-400w.webp 400w, /images/gallery-2-800w.webp 800w',
    fallbackSrcset: '/images/gallery-2-400w.jpeg 400w, /images/gallery-2-800w.jpeg 800w',
    fallbackType: 'image/jpeg',
    alt: 'Seasonal floral arrangement with soft pink tones',
    width: 800, height: 600,
  },
  {
    src: '/images/gallery-3.jpeg',
    webpSrcset: '/images/gallery-3-400w.webp 400w, /images/gallery-3-800w.webp 800w',
    fallbackSrcset: '/images/gallery-3-400w.jpeg 400w, /images/gallery-3-800w.jpeg 800w',
    fallbackType: 'image/jpeg',
    alt: 'Luxury floral design with natural greenery',
    width: 800, height: 600,
  },
  {
    src: '/images/gallery-4.jpeg',
    webpSrcset: '/images/gallery-4-400w.webp 400w, /images/gallery-4-800w.webp 800w',
    fallbackSrcset: '/images/gallery-4-400w.jpeg 400w, /images/gallery-4-800w.jpeg 800w',
    fallbackType: 'image/jpeg',
    alt: 'Romantic floral composition for a living space',
    width: 800, height: 600,
  },
  {
    src: '/images/founder.jpeg',
    webpSrcset: '/images/founder-400w.webp 400w, /images/founder-800w.webp 800w',
    fallbackSrcset: '/images/founder-400w.jpeg 400w, /images/founder-800w.jpeg 800w',
    fallbackType: 'image/jpeg',
    alt: 'Artful arrangement in a Windermere home',
    width: 800, height: 1000,
  },
];
---

<section class="gallery section section-linen" id="portfolio" aria-label="Portfolio">
  <div class="container">
    <h2 class="heading-section reveal">Portfolio</h2>
    <div class="gallery__grid reveal-stagger">
      {images.map((img, i) => (
        <div class={`gallery__item reveal-child ${i === 0 ? 'gallery__item--wide' : ''}`}>
          <picture>
            <source
              type="image/webp"
              srcset={img.webpSrcset}
              sizes={i === 0 ? '(min-width: 1024px) 66vw, 100vw' : '(min-width: 1024px) 33vw, (min-width: 768px) 50vw, 100vw'}
            >
            <source
              type={img.fallbackType}
              srcset={img.fallbackSrcset}
              sizes={i === 0 ? '(min-width: 1024px) 66vw, 100vw' : '(min-width: 1024px) 33vw, (min-width: 768px) 50vw, 100vw'}
            >
            <img
              src={img.src}
              alt={img.alt}
              loading="lazy"
              width={img.width}
              height={img.height}
            >
          </picture>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .gallery__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 8px;
  }

  @media (min-width: 768px) {
    .gallery__grid {
      grid-template-columns: repeat(2, 1fr);
      gap: 10px;
    }

    .gallery__item--wide {
      grid-column: span 2;
    }
  }

  @media (min-width: 1024px) {
    .gallery__grid {
      grid-template-columns: repeat(3, 1fr);
      gap: 10px;
    }

    .gallery__item--wide {
      grid-column: span 2;
    }
  }

  .gallery__item {
    overflow: hidden;
    border-radius: 4px;
  }

  .gallery__item img {
    width: 100%;
    height: 380px;
    object-fit: cover;
    border-radius: 4px;
    transition: transform 0.6s var(--ease-out);
  }

  .gallery__item--wide img {
    height: 100%;
    min-height: 380px;
  }

  @media (min-width: 768px) {
    .gallery__item img { height: 420px; }
  }

  @media (hover: hover) {
    .gallery__item:hover img {
      transform: scale(1.02);
    }
  }

  @media (max-width: 767px) {
    .gallery__grid { gap: 0; }
    .gallery__item { border-radius: 0; }
    .gallery__item img { border-radius: 0; }
  }
</style>
