---
const year = new Date().getFullYear();
---

<footer class="footer">
  <div class="footer__inner">
    <p class="footer__brand">Perpetual Petals</p>
    <p class="footer__location">Windermere, Florida</p>

    <div class="footer__social">
      <a
        href="https://www.instagram.com/perpetualpetals_fl/"
        aria-label="Follow Perpetual Petals on Instagram"
        target="_blank"
        rel="noopener noreferrer"
      >
        <svg viewBox="0 0 24 24" width="22" height="22" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <rect x="2" y="2" width="20" height="20" rx="5" ry="5"/>
          <circle cx="12" cy="12" r="5"/>
          <circle cx="17.5" cy="6.5" r="1" fill="currentColor" stroke="none"/>
        </svg>
      </a>
    </div>

    <p class="footer__copyright">&copy; {year} Perpetual Petals. All rights reserved.</p>
    <p class="footer__credit">
      Website by <a href="https://vermillionaxis.com" target="_blank" rel="noopener noreferrer">Vermillion Axis Technologies</a>
    </p>
  </div>
</footer>

<style>
  .footer {
    padding: 60px var(--space-md) 40px;
    background: var(--color-linen);
    text-align: center;
    border-top: 1px solid var(--color-divider);
  }

  .footer__inner {
    max-width: var(--max-width);
    margin: 0 auto;
  }

  .footer__brand {
    font-family: var(--font-serif);
    font-weight: 300;
    font-size: 24px;
    color: var(--color-ink);
    letter-spacing: 1px;
    margin-bottom: 6px;
  }

  .footer__location {
    font-family: var(--font-sans);
    font-weight: 400;
    font-size: 11px;
    letter-spacing: 2.5px;
    text-transform: uppercase;
    color: var(--color-ink-muted);
    margin-bottom: var(--space-md);
  }

  .footer__social {
    margin-bottom: var(--space-md);
  }

  .footer__social a {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-width: 44px;
    min-height: 44px;
    color: var(--color-rose);
    transition: color 0.3s, transform 0.3s;
  }

  .footer__social a:hover {
    color: var(--color-rose-dark);
    transform: scale(1.1);
  }

  .footer__copyright {
    font-size: 11px;
    color: var(--color-ink-muted);
    margin-bottom: var(--space-sm);
  }

  .footer__credit {
    font-size: 9px;
    color: var(--color-rose);
    letter-spacing: 1px;
  }

  .footer__credit a {
    color: inherit;
    text-decoration: none;
    transition: opacity 0.3s;
  }

  .footer__credit a:hover { opacity: 0.7; }
</style>
