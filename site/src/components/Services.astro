---
/* Services — two service cards side by side */
---

<section class="services section section-linen" id="services" aria-label="Services">
  <div class="container">
    <span class="overline">Memberships</span>
    <h2 class="heading-section reveal">Services</h2>
    <div class="services__grid reveal-stagger">

      <div class="service-card reveal-child">
        <div class="service-card__icon" aria-hidden="true">
          <svg width="36" height="36" viewBox="0 0 36 36" fill="none" stroke="var(--color-gold)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" xmlns="http://www.w3.org/2000/svg">
            <rect x="4" y="6" width="28" height="26" rx="3" />
            <line x1="4" y1="14" x2="32" y2="14" />
            <line x1="12" y1="4" x2="12" y2="9" />
            <line x1="24" y1="4" x2="24" y2="9" />
            <path d="M16 22 C16 20 18 18 18 18 C18 18 20 20 20 22 C20 24 18 25 18 25 C18 25 16 24 16 22 Z" />
            <line x1="18" y1="25" x2="18" y2="28" />
            <line x1="16" y1="27" x2="18" y2="25" />
            <line x1="20" y1="27" x2="18" y2="25" />
          </svg>
        </div>
        <h3 class="heading-card">Private Membership</h3>
        <p class="label-muted service-card__avail">Limited Availability</p>
        <ul class="service-card__list">
          <li>Weekly, seasonal, or monthly floral placement</li>
          <li>Premium garden roses &amp; seasonal blooms</li>
          <li>Vessel rotation &amp; arrangement exchange</li>
          <li>Priority access for special occasions</li>
        </ul>
        <a href="#apply" class="btn btn-outline">Inquire</a>
      </div>

      <div class="service-card reveal-child">
        <div class="service-card__icon" aria-hidden="true">
          <svg width="36" height="36" viewBox="0 0 36 36" fill="none" stroke="var(--color-gold)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" xmlns="http://www.w3.org/2000/svg">
            <path d="M18 8 C18 8 22 4 26 6 C30 8 28 14 18 18 C8 14 6 8 10 6 C14 4 18 8 18 8 Z" />
            <path d="M10 18 L8 30 L18 26 L28 30 L26 18" />
            <circle cx="14" cy="22" r="1.5" />
            <circle cx="22" cy="22" r="1.5" />
            <circle cx="18" cy="26" r="1" />
          </svg>
        </div>
        <h3 class="heading-card">Events &amp; Gatherings</h3>
        <p class="label-muted service-card__avail">By Request</p>
        <ul class="service-card__list">
          <li>Custom floral styling for your occasion</li>
          <li>Dinner parties, celebrations, holidays</li>
          <li>Thoughtfully curated to complement your space</li>
        </ul>
        <a href="#apply" class="btn btn-outline">Submit Inquiry</a>
      </div>

    </div>
  </div>
</section>

<style>
  .services__grid {
    display: flex;
    flex-direction: column;
    gap: 24px;
  }

  @media (min-width: 768px) {
    .services__grid {
      flex-direction: row;
      gap: 32px;
    }
  }

  @media (min-width: 1024px) {
    .services__grid {
      gap: 48px;
    }
  }

  .service-card {
    flex: 1;
    background: var(--color-white);
    border: 1px solid var(--color-card-border);
    border-radius: 10px;
    padding: 52px;
    text-align: center;
    transition:
      transform var(--duration) var(--ease-out),
      border-color var(--duration) var(--ease-out),
      box-shadow var(--duration) var(--ease-out);
  }

  @media (hover: hover) {
    .service-card:hover {
      transform: translateY(-4px);
      border-color: var(--color-rose);
      box-shadow:
        0 12px 40px rgba(201, 160, 142, 0.15),
        0 4px 12px rgba(201, 160, 142, 0.1);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .service-card {
      transition: none;
    }
    .service-card:hover {
      transform: none;
    }
  }

  .service-card__icon {
    margin-bottom: 20px;
  }

  .service-card .heading-card {
    margin-bottom: var(--space-md);
  }

  .service-card__avail {
    margin-bottom: var(--space-md);
  }

  .service-card__list {
    list-style: none;
    margin-bottom: 36px;
  }

  .service-card__list li {
    font-family: var(--font-sans);
    font-weight: 400;
    font-size: 15px;
    line-height: 1.85;
    color: var(--color-ink-soft);
    padding: 14px 0;
    border-bottom: 1px solid var(--color-divider, var(--color-rose-glow));
  }

  .service-card__list li:last-child {
    border-bottom: none;
  }
</style>
