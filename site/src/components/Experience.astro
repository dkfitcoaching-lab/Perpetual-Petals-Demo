---
/* The Experience — 3-step process cards with custom SVG icons */
const steps = [
  {
    label: 'Inquiry',
    text: 'Share your vision and space. Membership begins with an approved application and a conversation about what you love.',
  },
  {
    label: 'Design',
    text: 'Arrangements are curated seasonally and intuitively. No two designs are ever alike — each reflects the moment and the setting.',
  },
  {
    label: 'Placement',
    text: 'Delivered and placed with intention. Refreshed on your schedule — weekly, seasonal, or monthly. Always alive.',
  },
];
---

<section class="experience section section-linen" id="experience" aria-label="How it works">
  <div class="container">
    <p class="overline reveal">The Experience</p>
    <h2 class="heading-section reveal">A Considered Process</h2>
    <div class="experience__steps reveal-stagger">

      <div class="experience__step reveal-child">
        <div class="experience__icon" aria-hidden="true">
          <svg width="40" height="40" viewBox="0 0 40 40" fill="none" stroke="var(--color-gold)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" xmlns="http://www.w3.org/2000/svg">
            <rect x="4" y="8" width="32" height="24" rx="3" />
            <polyline points="4,8 20,22 36,8" />
          </svg>
        </div>
        <p class="experience__label">{steps[0].label}</p>
        <p class="body-text">{steps[0].text}</p>
      </div>

      <div class="experience__step reveal-child">
        <div class="experience__icon" aria-hidden="true">
          <svg width="40" height="40" viewBox="0 0 40 40" fill="none" stroke="var(--color-gold)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" xmlns="http://www.w3.org/2000/svg">
            <path d="M8 36 L12 4" />
            <path d="M10 4 C10 4 18 6 16 14 C14 22 22 18 20 12 C18 6 26 2 28 10" />
            <circle cx="28" cy="14" r="6" />
            <circle cx="22" cy="28" r="4" />
            <circle cx="32" cy="26" r="3" />
          </svg>
        </div>
        <p class="experience__label">{steps[1].label}</p>
        <p class="body-text">{steps[1].text}</p>
      </div>

      <div class="experience__step reveal-child">
        <div class="experience__icon" aria-hidden="true">
          <svg width="40" height="40" viewBox="0 0 40 40" fill="none" stroke="var(--color-gold)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" xmlns="http://www.w3.org/2000/svg">
            <path d="M12 36 L14 22 L26 22 L28 36 Z" />
            <path d="M14 22 C14 22 10 18 10 14 C10 10 14 6 20 6 C26 6 30 10 30 14 C30 18 26 22 26 22" />
            <line x1="20" y1="6" x2="20" y2="2" />
            <line x1="14" y1="8" x2="11" y2="4" />
            <line x1="26" y1="8" x2="29" y2="4" />
          </svg>
        </div>
        <p class="experience__label">{steps[2].label}</p>
        <p class="body-text">{steps[2].text}</p>
      </div>

    </div>
  </div>
</section>

<style>
  .experience__steps {
    display: flex;
    flex-direction: column;
    gap: 32px;
  }

  @media (min-width: 768px) {
    .experience__steps {
      flex-direction: row;
      gap: 40px;
    }
  }

  @media (min-width: 1024px) {
    .experience__steps {
      gap: 56px;
    }
  }

  .experience__step {
    flex: 1;
    text-align: center;
    padding: 48px;
    border: 1px solid var(--color-card-border);
    border-radius: 8px;
    background: white;
    transition:
      transform 0.3s var(--ease-out),
      border-color 0.3s var(--ease-out),
      box-shadow 0.3s var(--ease-out);
  }

  @media (hover: hover) {
    .experience__step:hover {
      transform: translateY(-6px);
      border-color: var(--color-rose);
      box-shadow:
        0 12px 40px rgba(201, 160, 142, 0.15),
        0 4px 12px rgba(201, 160, 142, 0.1);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .experience__step {
      transition: none;
    }
    .experience__step:hover {
      transform: none;
    }
  }

  .experience__icon {
    margin-bottom: 20px;
  }

  .experience__label {
    font-family: var(--font-serif);
    font-weight: 400;
    font-style: italic;
    font-size: 26px;
    color: var(--color-rose);
    margin-bottom: var(--space-sm);
  }

  .experience__step .body-text {
    max-width: 320px;
    margin: 0 auto;
    font-size: 15px;
    line-height: 1.7;
  }
</style>
