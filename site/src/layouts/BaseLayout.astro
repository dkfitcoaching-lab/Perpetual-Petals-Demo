---
interface Props {
  title: string;
  description?: string;
}

const { title, description = 'Perpetual Petals — Private Floral Membership | Windermere, Florida' } = Astro.props;
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{title}</title>
  <meta name="description" content={description}>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,500;1,300;1,400;1,500&family=Raleway:wght@300;400&display=swap" rel="stylesheet">
</head>
<body>
  <nav class="site-nav">
    <div class="nav-inner">
      <a href="/" class="nav-logo">Perpetual Petals</a>
    </div>
  </nav>

  <main>
    <slot />
  </main>

  <footer class="site-footer">
    <div class="footer-inner">
      <p>&copy; {new Date().getFullYear()} Perpetual Petals. All rights reserved.</p>
    </div>
  </footer>
</body>
</html>

<style is:global>
  @import '../styles/global.css';
</style>

<style>
  .site-nav {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 100;
    background: rgba(253, 249, 246, 0.95);
    backdrop-filter: blur(10px);
    border-bottom: 1px solid var(--warm);
  }

  .nav-inner {
    max-width: 1200px;
    margin: 0 auto;
    padding: 20px 48px;
    display: flex;
    align-items: center;
  }

  .nav-logo {
    font-family: 'Cormorant Garamond', serif;
    font-size: 1.5rem;
    font-weight: 400;
    letter-spacing: 0.08em;
    color: var(--text);
  }

  main {
    padding-top: 80px;
  }

  .site-footer {
    border-top: 1px solid var(--warm);
    padding: 40px 48px;
    text-align: center;
  }

  .footer-inner {
    max-width: 1200px;
    margin: 0 auto;
    font-size: 0.85rem;
    color: var(--text-caption);
    letter-spacing: 0.04em;
  }
</style>
