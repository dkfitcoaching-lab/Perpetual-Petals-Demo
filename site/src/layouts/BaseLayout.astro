---
import Navigation from '../components/Navigation.astro';
import Footer from '../components/Footer.astro';
import Analytics from '../components/Analytics.astro';
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
  noindex?: boolean;
}

const {
  title = 'Perpetual Petals — Private Floral Membership | Windermere, Florida',
  description = 'Perpetual Petals is a private floral design membership in Windermere, Florida. Premium garden roses, seasonal blooms, and bespoke arrangements.',
  ogImage = '/images/og-image.jpg',
  noindex = false,
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site);
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{title}</title>
  <meta name="description" content={description}>
  {noindex && <meta name="robots" content="noindex, nofollow">}
  <meta name="theme-color" content="#FDF8F6">
  <link rel="canonical" href={canonicalURL}>

  <!-- Favicon -->
  <link rel="icon" type="image/svg+xml" href="/favicon.svg">
  <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32.png">
  <link rel="apple-touch-icon" href="/apple-touch-icon.png">

  <!-- Open Graph -->
  <meta property="og:type" content="website">
  <meta property="og:url" content={canonicalURL}>
  <meta property="og:title" content={title}>
  <meta property="og:description" content={description}>
  <meta property="og:image" content={new URL(ogImage, Astro.site).href}>
  <meta property="og:locale" content="en_US">
  <meta property="og:site_name" content="Perpetual Petals">

  <!-- Twitter / X -->
  <meta name="twitter:card" content="summary_large_image">
  <meta name="twitter:title" content={title}>
  <meta name="twitter:description" content={description}>
  <meta name="twitter:image" content={new URL(ogImage, Astro.site).href}>

  <!-- Preload critical fonts -->
  <link rel="preload" href="/fonts/cormorant-garamond-latin-300-normal.woff2" as="font" type="font/woff2" crossorigin>
  <link rel="preload" href="/fonts/raleway-latin-400-normal.woff2" as="font" type="font/woff2" crossorigin>

  <!-- Preload hero image -->
  <link rel="preload" href="/images/hero-arrangement.png" as="image" type="image/png">

  <!-- Structured Data: LocalBusiness -->
  <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "LocalBusiness",
      "name": "Perpetual Petals",
      "description": "Private floral design membership serving luxury homes in Windermere, Florida.",
      "url": "https://perpetual-petals.com",
      "image": "https://perpetual-petals.com/images/hero-arrangement.png",
      "address": {
        "@type": "PostalAddress",
        "addressLocality": "Windermere",
        "addressRegion": "FL",
        "addressCountry": "US"
      },
      "areaServed": {
        "@type": "Place",
        "name": "Windermere, Florida"
      },
      "serviceType": ["Floral Design", "Floral Membership", "Event Florals"],
      "priceRange": "$$$$"
    }
  </script>
</head>
<body>
  <a href="#main-content" class="skip-link">Skip to content</a>
  <Navigation />

  <main id="main-content">
    <slot />
  </main>

  <Footer />

  <Analytics />

  <!-- Scroll reveal observer -->
  <script>
    if ('IntersectionObserver' in window) {
      const prefersReduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

      if (!prefersReduced) {
        const revealObserver = new IntersectionObserver((entries) => {
          entries.forEach(entry => {
            if (entry.isIntersecting) {
              entry.target.classList.add('visible');
              revealObserver.unobserve(entry.target);
            }
          });
        }, { threshold: 0.15, rootMargin: '0px 0px -80px 0px' });

        document.querySelectorAll('.reveal').forEach(el => revealObserver.observe(el));

        const staggerObserver = new IntersectionObserver((entries) => {
          entries.forEach(entry => {
            if (entry.isIntersecting) {
              entry.target.classList.add('visible');
              entry.target.querySelectorAll('.reveal-child').forEach((child, i) => {
                (child as HTMLElement).style.transitionDelay = `${i * 0.18}s`;
              });
              staggerObserver.unobserve(entry.target);
            }
          });
        }, { threshold: 0.1 });

        document.querySelectorAll('.reveal-stagger').forEach(el => staggerObserver.observe(el));

        // Founder image parallax
        const founderImg = document.querySelector('.founder__image') as HTMLElement | null;
        if (founderImg) {
          const founderSection = founderImg.closest('.founder') as HTMLElement | null;
          if (founderSection) {
            const parallaxObserver = new IntersectionObserver((entries) => {
              entries.forEach(entry => {
                if (entry.isIntersecting) {
                  window.addEventListener('scroll', function founderParallax() {
                    const rect = founderSection.getBoundingClientRect();
                    const viewH = window.innerHeight;
                    if (rect.bottom < 0 || rect.top > viewH) return;
                    const progress = (viewH - rect.top) / (viewH + rect.height);
                    const shift = (progress - 0.5) * 40;
                    founderImg.style.transform = `translateY(${shift}px) translateZ(0)`;
                  }, { passive: true });
                }
              });
            }, { threshold: 0 });
            parallaxObserver.observe(founderSection);
          }
        }
      }
    }
  </script>

  <!-- Back to top -->
  <button class="back-to-top" id="backToTop" aria-label="Back to top" type="button">
    <svg width="20" height="20" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
      <polyline points="15 12 10 7 5 12"/>
    </svg>
  </button>

  <script>
    const backToTop = document.getElementById('backToTop');
    if (backToTop) {
      window.addEventListener('scroll', () => {
        if (window.scrollY > 600) {
          backToTop.classList.add('visible');
        } else {
          backToTop.classList.remove('visible');
        }
      }, { passive: true });
      backToTop.addEventListener('click', () => {
        window.scrollTo({ top: 0, behavior: 'smooth' });
      });
    }
  </script>
</body>
</html>
