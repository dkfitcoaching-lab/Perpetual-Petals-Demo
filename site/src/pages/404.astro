---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Page Not Found — Perpetual Petals" description="The page you're looking for doesn't exist. Return to Perpetual Petals." noindex={true}>
  <section class="not-found">
    <div class="not-found-content">
      <div class="petal-decoration" aria-hidden="true">
        <svg viewBox="0 0 120 120" class="petal-svg">
          <ellipse cx="60" cy="30" rx="18" ry="28" fill="#855E4A" opacity="0.15" transform="rotate(0 60 60)" />
          <ellipse cx="60" cy="30" rx="18" ry="28" fill="#855E4A" opacity="0.12" transform="rotate(72 60 60)" />
          <ellipse cx="60" cy="30" rx="18" ry="28" fill="#855E4A" opacity="0.10" transform="rotate(144 60 60)" />
          <ellipse cx="60" cy="30" rx="18" ry="28" fill="#855E4A" opacity="0.12" transform="rotate(216 60 60)" />
          <ellipse cx="60" cy="30" rx="18" ry="28" fill="#855E4A" opacity="0.15" transform="rotate(288 60 60)" />
          <circle cx="60" cy="60" r="6" fill="#855E4A" opacity="0.25" />
        </svg>
      </div>

      <p class="error-code">404</p>

      <h1 class="error-title">This page doesn't exist</h1>

      <div class="divider-line" aria-hidden="true"></div>

      <p class="error-message">
        But something beautiful is waiting for you.
      </p>

      <a href="/" class="return-button">
        Return Home
      </a>
    </div>
  </section>
</BaseLayout>

<style>
  .not-found {
    min-height: calc(100vh - 80px);
    display: flex;
    align-items: center;
    justify-content: center;
    text-align: center;
    padding: 80px 24px;
    position: relative;
    overflow: hidden;
  }

  .not-found-content {
    position: relative;
    z-index: 1;
    max-width: 520px;
  }

  .petal-decoration {
    margin: 0 auto 40px;
    width: 120px;
    height: 120px;
    animation: gentle-spin 60s linear infinite;
  }

  .petal-svg {
    width: 100%;
    height: 100%;
  }

  @keyframes gentle-spin {
    from { transform: rotate(0deg); }
    to { transform: rotate(360deg); }
  }

  @media (prefers-reduced-motion: reduce) {
    .petal-decoration {
      animation: none;
    }
  }

  .error-code {
    font-family: 'Cormorant Garamond', serif;
    font-size: 5rem;
    font-weight: 300;
    color: var(--color-blush);
    letter-spacing: 0.15em;
    line-height: 1;
    margin-bottom: 16px;
  }

  .error-title {
    font-family: 'Cormorant Garamond', serif;
    font-size: 2rem;
    font-weight: 300;
    color: var(--color-ink);
    letter-spacing: 0.04em;
    line-height: 1.3;
    margin-bottom: 24px;
  }

  .divider-line {
    width: 48px;
    height: 1px;
    background: var(--color-rose);
    margin: 0 auto 24px;
    opacity: 0.5;
  }

  .error-message {
    font-family: 'Cormorant Garamond', serif;
    font-style: italic;
    font-size: 1.25rem;
    color: var(--color-ink-soft);
    letter-spacing: 0.02em;
    line-height: 1.6;
    margin-bottom: 48px;
  }

  .return-button {
    display: inline-block;
    font-family: 'Raleway', sans-serif;
    font-size: 0.8rem;
    font-weight: 400;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--color-ink);
    border: 1px solid var(--color-rose);
    padding: 16px 48px;
    transition: background-color 0.4s ease, color 0.4s ease;
  }

  .return-button:hover {
    background-color: var(--color-rose);
    color: var(--color-white);
  }

  @media (max-width: 600px) {
    .error-code {
      font-size: 3.5rem;
    }
    .error-title {
      font-size: 1.5rem;
    }
    .error-message {
      font-size: 1.1rem;
    }
  }
</style>
