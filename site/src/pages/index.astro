---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Perpetual Petals — Private Floral Membership | Windermere, Florida">
  <section style="min-height: 60vh; display: flex; align-items: center; justify-content: center; text-align: center; padding: 80px 24px;">
    <div>
      <h1 style="font-family: 'Cormorant Garamond', serif; font-size: 3rem; font-weight: 300; color: var(--text); margin-bottom: 16px;">Perpetual Petals</h1>
      <p style="color: var(--text-secondary); font-size: 1.1rem; letter-spacing: 0.06em;">Private Floral Membership — Windermere, Florida</p>
    </div>
  </section>
</BaseLayout>
